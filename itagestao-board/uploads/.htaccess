# Bloquear execução de scripts PHP nesta pasta
<FilesMatch "\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Permitir apenas tipos de arquivo seguros
<FilesMatch "\.(pdf|doc|docx|xls|xlsx|jpg|jpeg|png|gif|zip|rar)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

Options -Indexes
