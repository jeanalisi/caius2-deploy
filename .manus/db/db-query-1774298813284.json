{
  "query": "SELECT \n  t.TABLE_NAME,\n  t.TABLE_ROWS,\n  (SELECT COUNT(*) FROM INFORMATION_SCHEMA.COLUMNS c \n   WHERE c.TABLE_NAME = t.TABLE_NAME AND c.TABLE_SCHEMA = t.TABLE_SCHEMA AND c.EXTRA LIKE '%auto_increment%') as has_autoincrement,\n  (SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLE_CONSTRAINTS tc \n   WHERE tc.TABLE_NAME = t.TABLE_NAME AND tc.TABLE_SCHEMA = t.TABLE_SCHEMA AND tc.CONSTRAINT_TYPE = 'PRIMARY KEY') as has_primary_key\nFROM INFORMATION_SCHEMA.TABLES t\nWHERE t.TABLE_SCHEMA = DATABASE()\n  AND t.TABLE_TYPE = 'BASE TABLE'\n  AND t.TABLE_NAME NOT IN ('__drizzle_migrations', 'accounts_old', 'botFlows', 'botNodes', 'botSessions', 'botSessionLogs')\n  AND (\n    (SELECT COUNT(*) FROM INFORMATION_SCHEMA.COLUMNS c \n     WHERE c.TABLE_NAME = t.TABLE_NAME AND c.TABLE_SCHEMA = t.TABLE_SCHEMA AND c.EXTRA LIKE '%auto_increment%') = 0\n    OR\n    (SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLE_CONSTRAINTS tc \n     WHERE tc.TABLE_NAME = t.TABLE_NAME AND tc.TABLE_SCHEMA = t.TABLE_SCHEMA AND tc.CONSTRAINT_TYPE = 'PRIMARY KEY') = 0\n  )\nORDER BY t.TABLE_NAME;",
