# ─── CAIUS2 — Variáveis de Ambiente ──────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores antes de iniciar o servidor.
# O arquivo .env NUNCA deve ser commitado no repositório (já está no .gitignore).

# ─── Servidor ────────────────────────────────────────────────────────────────

# Ambiente de execução: development | production
NODE_ENV=production

# Porta do servidor HTTP (padrão: 3000)
PORT=3000

# URL pública da aplicação (usada em links de e-mail, convites, etc.)
# IMPORTANTE: sem barra no final
PUBLIC_URL=https://cac.itabaiana.pb.gov.br

# ─── Banco de Dados ───────────────────────────────────────────────────────────

# String de conexão MySQL/TiDB
# Exemplo: mysql://usuario:senha@host:4000/nome_do_banco?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://usuario:senha@host:4000/caius2

# ─── Autenticação ─────────────────────────────────────────────────────────────

# Segredo para assinar tokens JWT (use uma string longa e aleatória)
JWT_SECRET=troque-por-uma-string-secreta-longa

# ─── OAuth / SSO (opcional) ───────────────────────────────────────────────────

# URL do servidor OAuth para login federado (deixe em branco se não usar)
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ─── IA / Forge API (opcional) ────────────────────────────────────────────────

# Chave e URL da API de IA integrada ao CAIUS (Forge/OpenAI-compatible)
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# Variáveis prefixadas com VITE_ são expostas ao cliente (browser)

# ID e URL da aplicação (exibidos na interface)
VITE_APP_ID=caius2
VITE_APP_TITLE=CAIUS — Central de Atendimento
VITE_APP_URL=https://cac.itabaiana.pb.gov.br

# Logo customizado (URL ou caminho relativo ao /public)
VITE_APP_LOGO=

# API de IA exposta ao frontend (opcional)
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# Portal OAuth para login (opcional)
VITE_OAUTH_PORTAL_URL=
